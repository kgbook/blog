<article class="article archives-about article-type-normal" itemscope="">
  <header class="article-header">
    <% if(theme.site.logo && theme.site.logo.enabled) { %>
    <div class="about-brand">
      <img class="about-brand-logo" src="<%- url_for((theme.site.logo.url || '').replace(/^\.\.\//, '')) %>" width="<%= theme.site.logo.width * 2 %>" height="<%= theme.site.logo.height * 2 %>" alt="<%= theme.site.title || config.title %>">
      <div class="about-brand-copy">
        <div class="about-brand-name"><%= theme.site.title || config.title %></div>
        <div class="about-brand-tagline">Code, systems, and AI</div>
      </div>
    </div>
    <% } %>
    <h1 itemprop="title"><%= page.title %></h1>
    <% if(page.description || theme.profile.author_description) { %>
    <p class="text-muted"><%= page.description || theme.profile.author_description %></p>
    <% } %>
  </header>
  <div class="article-body">
    <%- page.content %>
  </div>
</article>
<% if (theme.comment.type && !is_home()) { %>
  <%- partial('post/comment', {post: page}) %>
<% } %>
